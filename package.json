{
  "name": "portal-chamados-e2e",
  "version": "1.0.0",
  "description": "End-to-end and API test suite for Portal de Chamados using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:api": "npm run test:api:full",
    "test:api:full": "playwright test tests/portal-chamados/portal-api.spec.js",
    "test:api:smoke": "playwright test tests/portal-chamados/portal-api.spec.js --grep \"\\[HAPPY\\].*(POST /auth/login|GET /users|GET /tickets|GET /companies|GET /roles)\"",
    "test:ui:portal": "playwright test tests/portal-chamados/portal-auth.spec.js",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "codegen": "playwright codegen",
    "report": "playwright show-report",
    "clean": "node -e \"const fs=require('fs'),p=require('path'),dirs=['playwright-report','screenshots/chromium','screenshots/firefox','screenshots/webkit','videos/chromium','videos/firefox','videos/webkit','test-results/chromium','test-results/firefox','test-results/webkit'];dirs.forEach(d=>{const full=p.join(__dirname,d);fs.rmSync(full,{recursive:true,force:true});fs.mkdirSync(full,{recursive:true});});console.log('Evidences cleaned.');\""
  },
  "keywords": [
    "playwright",
    "e2e",
    "api-testing",
    "automation",
    "portal-chamados"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.0"
  }
}
